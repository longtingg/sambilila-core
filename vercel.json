{
  "version": 2,
  "builds": [
    {
      "src": "core_project/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "pipArgs": "--upgrade",
        "runtime": "python3.12"
      }
    }
  ],
  "env": {
    "DATABASE_URL": "PASTE_YOUR_NEON_DATABASE_URL_HERE",
    "DEBUG": "False"
  },
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "core_project/wsgi.py"
    }
  ]
}
